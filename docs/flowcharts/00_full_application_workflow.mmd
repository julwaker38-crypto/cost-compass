flowchart TD
    %% ========== OVERVIEW ==========
    START((Vendor Buka Sistem)) --> AUTH[Login / Autentikasi]
    AUTH --> DASHBOARD[Dashboard Utama]
    DASHBOARD --> PHASE1[1 - Pembelian Bahan Baku]
    DASHBOARD --> PHASE2[2 - Pengecekan Bahan Baku]
    DASHBOARD --> PHASE3[3 - Produksi Menu]
    DASHBOARD --> PHASE4[4 - Pencatatan Total Porsi]
    DASHBOARD --> PHASE5[5 - Laporan]

    %% ========== PHASE 1: PEMBELIAN BAHAN BAKU ==========
    PHASE1 --> P1_BELANJA[Isi Data Belanjaan]
    P1_BELANJA --> P1_INPUT_NAMA[Input Nama Bahan Baku]
    P1_INPUT_NAMA --> P1_INPUT_GRAM[Input Total Gramasi]
    P1_INPUT_GRAM --> P1_INPUT_HARGA[Input Harga Bahan]
    P1_INPUT_HARGA --> P1_MORE{Tambah Bahan Lagi?}
    P1_MORE -->|Ya| P1_INPUT_NAMA
    P1_MORE -->|Tidak| P1_MENU[Isi Data Menu Produksi]

    P1_MENU --> P1_MENU_NAMA[Input Nama Menu]
    P1_MENU_NAMA --> P1_SELECT_BAHAN[Pilih Bahan dari Data Belanjaan]
    P1_SELECT_BAHAN --> P1_GRAM_PER_PORSI[Input Gramasi Tiap Bahan per Porsi]
    P1_GRAM_PER_PORSI --> P1_MORE_BAHAN{Tambah Bahan ke Menu?}
    P1_MORE_BAHAN -->|Ya| P1_SELECT_BAHAN
    P1_MORE_BAHAN -->|Tidak| P1_AUTO[Kalkulasi Otomatis]

    P1_AUTO --> P1_GIZI[Hitung Kandungan Gizi]
    P1_AUTO --> P1_MODAL[Hitung Modal Tiap Bahan per Porsi]
    P1_AUTO --> P1_TOTAL_PORSI[Hitung Total Porsi yang Dapat Dibuat]

    P1_GIZI --> P1_SAVE[Simpan Data Menu]
    P1_MODAL --> P1_SAVE
    P1_TOTAL_PORSI --> P1_SAVE

    P1_SAVE --> P1_MORE_MENU{Tambah Menu Lagi?}
    P1_MORE_MENU -->|Ya| P1_MENU_NAMA
    P1_MORE_MENU -->|Tidak| P1_DONE[Data Pembelian dan Menu Tersimpan]

    %% ========== PHASE 2: PENGECEKAN BAHAN BAKU ==========
    PHASE2 --> P2_TERIMA[Bahan Baku Datang dari Supplier]
    P2_TERIMA --> P2_SCANNER[Letakkan di Smart Scanner]
    P2_SCANNER --> P2_AUTO_CHECK[Sistem Otomatis Cek Kualitas]
    P2_AUTO_CHECK --> P2_CLASSIFY{Klasifikasi Hasil}

    P2_CLASSIFY -->|Layak| P2_LAYAK[Bahan Baku Layak]
    P2_CLASSIFY -->|Tidak Layak| P2_TIDAK_LAYAK[Bahan Baku Tidak Layak]

    P2_TIDAK_LAYAK --> P2_MANUAL[Cross Check Manual oleh Petugas]
    P2_MANUAL --> P2_MANUAL_RESULT{Hasil Manual Check}
    P2_MANUAL_RESULT -->|Ternyata Layak| P2_LAYAK
    P2_MANUAL_RESULT -->|Tetap Tidak Layak| P2_REJECT[Bahan Ditolak dan Dicatat]

    P2_LAYAK --> P2_GUDANG[Masukkan ke Gudang Penyimpanan]
    P2_GUDANG --> P2_UPDATE_STOK[Update Stok Bahan di Sistem]

    %% ========== PHASE 3: PRODUKSI MENU ==========
    PHASE3 --> P3_APD[Karyawan Mengenakan APD]
    P3_APD --> P3_SCAN_APD[Scan APD di Smart Vision]
    P3_SCAN_APD --> P3_APD_CHECK{APD Lengkap?}
    P3_APD_CHECK -->|Tidak| P3_APD_ALERT[Alert: Lengkapi APD]
    P3_APD_ALERT --> P3_APD
    P3_APD_CHECK -->|Ya| P3_APPROVED[Karyawan Diizinkan Masuk Dapur]

    P3_APPROVED --> P3_AMBIL_BAHAN[Ambil Bahan Baku dari Gudang]
    P3_AMBIL_BAHAN --> P3_SCAN_BAHAN[Scan Bahan di Smart Scanner]
    P3_SCAN_BAHAN --> P3_BAHAN_CHECK{Bahan Masih Layak?}
    P3_BAHAN_CHECK -->|Tidak| P3_BAHAN_REJECT[Bahan Ditolak - Ganti Bahan Lain]
    P3_BAHAN_REJECT --> P3_AMBIL_BAHAN
    P3_BAHAN_CHECK -->|Ya| P3_MULAI[Mulai Produksi Menu]

    P3_MULAI --> P3_VISION[Smart Vision Mengawasi Produksi]
    P3_VISION --> P3_MONITOR_APD[Monitor Kepatuhan APD Selama Produksi]
    P3_VISION --> P3_MONITOR_SOP[Monitor Kepatuhan SOP Produksi]

    P3_MONITOR_APD --> P3_APD_VIOLATION{Pelanggaran APD?}
    P3_APD_VIOLATION -->|Ya| P3_APD_WARNING[Warning: Perbaiki APD]
    P3_APD_VIOLATION -->|Tidak| P3_CONTINUE[Produksi Berlanjut]

    P3_MONITOR_SOP --> P3_SOP_VIOLATION{Pelanggaran SOP?}
    P3_SOP_VIOLATION -->|Ya| P3_SOP_WARNING[Warning: Ikuti SOP]
    P3_SOP_VIOLATION -->|Tidak| P3_CONTINUE

    P3_CONTINUE --> P3_DONE[Produksi Selesai]

    %% ========== PHASE 4: PENCATATAN TOTAL PORSI ==========
    PHASE4 --> P4_INPUT[Vendor Catat Total Porsi Jadi]
    P4_INPUT --> P4_INPUT_MENU[Pilih Menu]
    P4_INPUT_MENU --> P4_INPUT_QTY[Input Jumlah Porsi Aktual]
    P4_INPUT_QTY --> P4_COMPARE[Sistem Bandingkan Prediksi vs Aktual]

    P4_COMPARE --> P4_MATCH{Sesuai Prediksi?}
    P4_MATCH -->|Ya| P4_OK[Status: Sesuai]
    P4_MATCH -->|Tidak| P4_DEVIATION[Catat Deviasi dan Alasan]

    P4_OK --> P4_PENERIMA[Catat Jumlah Penerima Manfaat]
    P4_DEVIATION --> P4_PENERIMA

    P4_PENERIMA --> P4_INPUT_PENERIMA[Input Total Penerima]
    P4_INPUT_PENERIMA --> P4_SAVE[Simpan Data Porsi dan Penerima]

    %% ========== PHASE 5: LAPORAN ==========
    PHASE5 --> P5_GENERATE[Sistem Generate Laporan Otomatis]
    P5_GENERATE --> P5_DASHBOARD[Dashboard Ringkasan Harian]
    P5_GENERATE --> P5_PDF[Dokumen Laporan Harian - PDF]

    P5_DASHBOARD --> P5_D_BELANJA[Ringkasan Belanja Bahan Baku]
    P5_DASHBOARD --> P5_D_QC[Hasil Quality Control Bahan]
    P5_DASHBOARD --> P5_D_PRODUKSI[Kepatuhan Produksi - APD dan SOP]
    P5_DASHBOARD --> P5_D_PORSI[Perbandingan Porsi Prediksi vs Aktual]
    P5_DASHBOARD --> P5_D_PENERIMA[Data Penerima Manfaat]
    P5_DASHBOARD --> P5_D_BIAYA[Analisa Biaya dan Modal]

    P5_PDF --> P5_PDF_CONTENT[Isi Dokumen PDF]
    P5_PDF_CONTENT --> P5_PDF_1[Data Pembelian Bahan Baku]
    P5_PDF_CONTENT --> P5_PDF_2[Hasil Pengecekan Kualitas]
    P5_PDF_CONTENT --> P5_PDF_3[Log Kepatuhan Produksi]
    P5_PDF_CONTENT --> P5_PDF_4[Rekapitulasi Porsi dan Penerima]
    P5_PDF_CONTENT --> P5_PDF_5[Ringkasan Keuangan Harian]

    P5_PDF --> P5_DOWNLOAD[Download Laporan PDF]
